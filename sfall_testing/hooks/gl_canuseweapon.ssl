#include "sfall.h"
#include "dik.h"
#include "define_lite.h"

#define TEST_KEY (DIK_U)

variable canuseweapon_blocking := false;

procedure canuseweapon_handler begin
    variable
        critter := get_sfall_arg_at(0),
        weapon := get_sfall_arg_at(1),
        hitMode := get_sfall_arg_at(2),
        engineResult := get_sfall_arg_at(3);

    display_msg(string_format("canuseweapon %s weapon=%s hitMode=%d engineResult=%d",
        obj_name(critter), obj_name(weapon), hitMode, engineResult));

    if (canuseweapon_blocking) then begin
        display_msg("canuseweapon BLOCKED (overriding engine allow)");
        set_sfall_return(0);
    end
end

procedure keypress_handler begin
    variable
        pressed := get_sfall_arg_at(0),
        key := get_sfall_arg_at(1);

    if (not pressed) then return;
    if (key != TEST_KEY) then return;

    canuseweapon_blocking := not canuseweapon_blocking;
    display_msg(string_format1("canuseweapon blocking=%d", canuseweapon_blocking));
end

procedure start begin
    if (not game_loaded) then return;

    display_msg("canuseweapon manual test ready: press U to toggle blocking");

    register_hook_proc(HOOK_KEYPRESS, keypress_handler);
    register_hook_proc(HOOK_CANUSEWEAPON, canuseweapon_handler);
end
